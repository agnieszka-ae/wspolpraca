{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Alloweat design tokens — wyciągnięte z prototypu autogeneracji v29. Format W3C Design Tokens (CG draft). Importowalne do Figma Variables, Tokens Studio, Style Dictionary.",
  "$metadata": {
    "name": "Alloweat",
    "version": "0.1.0",
    "source": "prototype v29 (autogeneracja jadłospisu)",
    "date": "2026-04-26"
  },

  "color": {
    "brand": {
      "default": { "$value": "#7448D0", "$type": "color", "$description": "Primary brand purple. Buttons, links, active states." },
      "dark":    { "$value": "#5915B2", "$type": "color", "$description": "Brand hover/active. End of primary gradient." },
      "darker":  { "$value": "#3D0A8F", "$type": "color", "$description": "Brand emphasis (rzadko, deep accents)." },
      "500":     { "$value": "#9B7DE0", "$type": "color", "$description": "Brand mid-tone (np. avatar fill)." },
      "400":     { "$value": "#F5F1FE", "$type": "color", "$description": "Brand background — subtle highlight, active chip bg." },
      "300":     { "$value": "#F6F1FF", "$type": "color", "$description": "Brand background — even lighter." },
      "200":     { "$value": "#F7F5FF", "$type": "color", "$description": "Brand background — sekcja highlighted." },
      "100":     { "$value": "#FAF7FF", "$type": "color", "$description": "Brand background — najsubtelniejsze tło." },
      "50":      { "$value": "#FBFAFC", "$type": "color", "$description": "Brand background — almost white tint." }
    },

    "ink": {
      "$description": "Neutralna skala — text, borders, backgrounds (jasny motyw).",
      "900": { "$value": "#141414", "$type": "color", "$description": "Primary text." },
      "800": { "$value": "#333333", "$type": "color", "$description": "Strong text." },
      "700": { "$value": "#727272", "$type": "color", "$description": "Secondary text." },
      "600": { "$value": "#4D516E", "$type": "color", "$description": "Tertiary text (z lekkim odcieniem fioletu)." },
      "500": { "$value": "#B4B4B4", "$type": "color", "$description": "Disabled text, placeholder." },
      "400": { "$value": "#D0D0D0", "$type": "color", "$description": "Strong border." },
      "300": { "$value": "#E5E5E5", "$type": "color", "$description": "Default border, divider." },
      "200": { "$value": "#F1F1F1", "$type": "color", "$description": "Subtle background, disabled bg." },
      "100": { "$value": "#FFFFFF", "$type": "color", "$description": "Canvas / cards background." }
    },

    "dark": {
      "$description": "Dark mode palette. Powerpurple-tinted surfaces (z mobile app designera).",
      "bg":             { "$value": "#0B080F", "$type": "color", "$description": "Page background." },
      "surface":        { "$value": "#1F1C22", "$type": "color", "$description": "Sidebars, topbar, main cards." },
      "elevated":       { "$value": "#2C292F", "$type": "color", "$description": "Modals, hover states, pills." },
      "surfaceTint":    { "$value": "#1C1532", "$type": "color", "$description": "Brand-tinted surface (brand-accented cards)." },
      "border":         { "$value": "#323036", "$type": "color", "$description": "Main borders." },
      "borderLight":    { "$value": "#3A3749", "$type": "color", "$description": "Subtle borders, dividers." },
      "text":           { "$value": "#EDECFF", "$type": "color", "$description": "Primary text — lavender-white." },
      "textBright":     { "$value": "#F7F5FF", "$type": "color", "$description": "Emphasized text." },
      "textMuted":      { "$value": "#D4CCE8", "$type": "color", "$description": "Secondary text." },
      "textDim":        { "$value": "#8B8B9E", "$type": "color", "$description": "Tertiary text, placeholders." },
      "accent":         { "$value": "#A67EEA", "$type": "color", "$description": "Light purple accent (icons, highlights)." },
      "accentBright":   { "$value": "#DBDBFF", "$type": "color", "$description": "Lavender text dla brand chipów." }
    },

    "graphite":   { "$value": "#31314D", "$type": "color", "$description": "Specific accent — header bg, meal time labels." },
    "deepviolet": { "$value": "#2D1D51", "$type": "color", "$description": "Modal backdrop overlay color." },

    "success": {
      "$description": "Sukces, pozytywny status. 4 warianty.",
      "dark":   { "$value": "#2A856C", "$type": "color", "$description": "Text color na light bg." },
      "default":{ "$value": "#3AB795", "$type": "color", "$description": "Default — checkmarks, success badge." },
      "light":  { "$value": "#EFF9F7", "$type": "color", "$description": "Light tonal bg dla success." },
      "bright": { "$value": "#4ECBA6", "$type": "color", "$description": "Dark mode highlight." }
    },

    "warning": {
      "$description": "Ostrzeżenie, uwaga. 4 warianty.",
      "dark":   { "$value": "#BF8000", "$type": "color", "$description": "Text color na light bg." },
      "default":{ "$value": "#E5A117", "$type": "color", "$description": "Default — warning icons." },
      "light":  { "$value": "#FFF6ED", "$type": "color", "$description": "Light tonal bg dla warning." },
      "bright": { "$value": "#FAB569", "$type": "color", "$description": "Dark mode highlight." }
    },

    "error": {
      "$description": "Błąd, akcja destruktywna. 4 warianty.",
      "dark":   { "$value": "#B53A45", "$type": "color", "$description": "Text color na light bg." },
      "default":{ "$value": "#D44450", "$type": "color", "$description": "Default — error icons, destructive actions." },
      "light":  { "$value": "#FEF0F1", "$type": "color", "$description": "Light tonal bg dla error." },
      "bright": { "$value": "#EC407A", "$type": "color", "$description": "Dark mode highlight." }
    },

    "info": {
      "$description": "Informacja, neutralny komunikat. 4 warianty.",
      "dark":   { "$value": "#4242B8", "$type": "color", "$description": "Text color na light bg." },
      "default":{ "$value": "#5252E5", "$type": "color", "$description": "Default — info icons, hints." },
      "light":  { "$value": "#F2F2FF", "$type": "color", "$description": "Light tonal bg dla info." },
      "bright": { "$value": "#8C8CFA", "$type": "color", "$description": "Dark mode highlight." }
    }
  },

  "gradient": {
    "brand":         { "$value": "linear-gradient(135deg, #7448D0 0%, #5915B2 100%)", "$type": "gradient", "$description": "Primary CTA, brand icons." },
    "brandSubtle":   { "$value": "linear-gradient(135deg, #F7F5FF 0%, #F5F1FE 100%)", "$type": "gradient", "$description": "Subtle brand tinted bg (np. dodatkowe sekcje)." },
    "brandVivid":    { "$value": "linear-gradient(135deg, #8B5CF6 0%, #6D28D9 50%, #5915B2 100%)", "$type": "gradient", "$description": "Hero/eye-catcher elements." }
  },

  "font": {
    "family": {
      "sans": { "$value": "Figtree, system-ui, sans-serif", "$type": "fontFamily", "$description": "Primary UI font." },
      "mono": { "$value": "JetBrains Mono, ui-monospace, monospace", "$type": "fontFamily", "$description": "Code, monospace values." }
    },
    "weight": {
      "regular":  { "$value": "400", "$type": "fontWeight" },
      "medium":   { "$value": "500", "$type": "fontWeight" },
      "semibold": { "$value": "600", "$type": "fontWeight" },
      "bold":     { "$value": "700", "$type": "fontWeight" }
    },
    "size": {
      "$description": "Skala typograficzna prototypu. Wartości w px.",
      "9":  { "$value": "9px",  "$type": "dimension", "$description": "Microcopy — dni tygodnia w schemacie." },
      "10": { "$value": "10px", "$type": "dimension", "$description": "Tag/chip label, badge." },
      "11": { "$value": "11px", "$type": "dimension", "$description": "Section label uppercase, hint, secondary microcopy." },
      "12": { "$value": "12px", "$type": "dimension", "$description": "Subtitle, secondary text, body 12." },
      "13": { "$value": "13px", "$type": "dimension", "$description": "Body, CTA text." },
      "14": { "$value": "14px", "$type": "dimension", "$description": "Card title, MealRow name." },
      "15": { "$value": "15px", "$type": "dimension", "$description": "Modal title, empty state title." },
      "16": { "$value": "16px", "$type": "dimension", "$description": "H2 sekcja, summary preset." },
      "22": { "$value": "22px", "$type": "dimension", "$description": "H1 ekran (np. nazwa programu)." }
    },
    "lineHeight": {
      "tight":  { "$value": "1.1", "$type": "number", "$description": "Tight headings." },
      "normal": { "$value": "1.5", "$type": "number", "$description": "Default body." },
      "relaxed":{ "$value": "1.625", "$type": "number", "$description": "Relaxed body / paragraphs." }
    },
    "letterSpacing": {
      "wider":  { "$value": "0.05em",  "$type": "dimension", "$description": "Section labels uppercase." },
      "widest": { "$value": "0.08em",  "$type": "dimension", "$description": "Microcopy headers (np. PODSUMOWANIE)." }
    }
  },

  "spacing": {
    "$description": "Bazowane na Tailwind defaults (1 unit = 4px). Wymienione tylko skala faktycznie używana w prototypie.",
    "0_5": { "$value": "2px",  "$type": "dimension" },
    "1":   { "$value": "4px",  "$type": "dimension", "$description": "Chip internal, ikona spacing." },
    "1_5": { "$value": "6px",  "$type": "dimension", "$description": "Chip row, kompakt." },
    "2":   { "$value": "8px",  "$type": "dimension", "$description": "Button group, default gap." },
    "2_5": { "$value": "10px", "$type": "dimension" },
    "3":   { "$value": "12px", "$type": "dimension", "$description": "Card internal padding, gap." },
    "4":   { "$value": "16px", "$type": "dimension", "$description": "Section spacing, large card padding." },
    "5":   { "$value": "20px", "$type": "dimension", "$description": "Modal section spacing." },
    "6":   { "$value": "24px", "$type": "dimension" },
    "8":   { "$value": "32px", "$type": "dimension", "$description": "Large section break." },
    "10":  { "$value": "40px", "$type": "dimension" },
    "12":  { "$value": "48px", "$type": "dimension" }
  },

  "radius": {
    "$description": "Border radius. Custom + Tailwind default.",
    "xs":   { "$value": "4px",  "$type": "dimension", "$description": "Small input, badge." },
    "sm":   { "$value": "8px",  "$type": "dimension", "$description": "Small button, mini-card." },
    "md":   { "$value": "12px", "$type": "dimension", "$description": "Card, button standardowy." },
    "lg":   { "$value": "16px", "$type": "dimension", "$description": "Large card, modal corners." },
    "xl":   { "$value": "20px", "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension", "$description": "Chip, avatar, circle button." }
  },

  "size": {
    "$description": "Standardowe wysokości komponentów.",
    "control": {
      "h7":  { "$value": "28px", "$type": "dimension", "$description": "Small chip, tag." },
      "h8":  { "$value": "32px", "$type": "dimension", "$description": "Standard chip, secondary button." },
      "h9":  { "$value": "36px", "$type": "dimension", "$description": "Primary CTA, input." },
      "h10": { "$value": "40px", "$type": "dimension", "$description": "Large CTA, footer button." }
    },
    "icon": {
      "xs": { "$value": "12px", "$type": "dimension", "$description": "Inline icon w tekście." },
      "sm": { "$value": "14px", "$type": "dimension", "$description": "Standardowa ikona button/chip." },
      "md": { "$value": "16px", "$type": "dimension", "$description": "Modal close, footer." },
      "lg": { "$value": "20px", "$type": "dimension", "$description": "Card header icon." },
      "xl": { "$value": "24px", "$type": "dimension", "$description": "Hero icon, modal header." }
    },
    "modal": {
      "narrow":  { "$value": "560px", "$type": "dimension", "$description": "NewProgram, simple modale." },
      "default": { "$value": "600px", "$type": "dimension", "$description": "MealplanGenerator, AutogenRecipes." },
      "wide":    { "$value": "680px", "$type": "dimension", "$description": "AutogenFromScratch (presety)." },
      "side":    { "$value": "640px", "$type": "dimension", "$description": "AddRecipesSidePanel — slide-in z prawej." }
    },
    "thumbnail": {
      "sm": { "$value": "32px", "$type": "dimension", "$description": "Avatar, mini icon." },
      "md": { "$value": "48px", "$type": "dimension", "$description": "Preset card icon." },
      "lg": { "$value": "56px", "$type": "dimension", "$description": "Recipe thumbnail w sidepanelu." }
    }
  },

  "shadow": {
    "e1": {
      "$value": [
        { "color": "rgba(20, 20, 20, 0.04)", "offsetX": "0", "offsetY": "1px",  "blur": "2px", "spread": "0" },
        { "color": "rgba(20, 20, 20, 0.05)", "offsetX": "0", "offsetY": "1px",  "blur": "3px", "spread": "0" }
      ],
      "$type": "shadow",
      "$description": "Card hover, subtle lift."
    },
    "e2": {
      "$value": [
        { "color": "rgba(20, 20, 20, 0.04)", "offsetX": "0", "offsetY": "2px", "blur": "4px", "spread": "-1px" },
        { "color": "rgba(20, 20, 20, 0.06)", "offsetX": "0", "offsetY": "4px", "blur": "8px", "spread": "-2px" }
      ],
      "$type": "shadow",
      "$description": "Sticky bar, dropdown."
    },
    "e3": {
      "$value": [
        { "color": "rgba(20, 20, 20, 0.08)", "offsetX": "0", "offsetY": "8px",  "blur": "16px", "spread": "-4px" },
        { "color": "rgba(45, 29, 81, 0.12)", "offsetX": "0", "offsetY": "12px", "blur": "32px", "spread": "-6px" }
      ],
      "$type": "shadow",
      "$description": "Popover, tooltip."
    },
    "e4": {
      "$value": [
        { "color": "rgba(45, 29, 81, 0.2)",  "offsetX": "0", "offsetY": "20px", "blur": "40px", "spread": "-8px" },
        { "color": "rgba(20, 20, 20, 0.08)", "offsetX": "0", "offsetY": "12px", "blur": "24px", "spread": "-6px" }
      ],
      "$type": "shadow",
      "$description": "Modal, sidepanel."
    },
    "brandSm": {
      "$value": [
        { "color": "rgba(116, 72, 208, 0.1)",  "offsetX": "0", "offsetY": "1px", "blur": "2px", "spread": "0" },
        { "color": "rgba(116, 72, 208, 0.15)", "offsetX": "0", "offsetY": "2px", "blur": "4px", "spread": "0" }
      ],
      "$type": "shadow",
      "$description": "Primary CTA — domyślny stan."
    },
    "brandMd": {
      "$value": [
        { "color": "rgba(116, 72, 208, 0.2)",  "offsetX": "0", "offsetY": "4px", "blur": "8px", "spread": "-1px" },
        { "color": "rgba(116, 72, 208, 0.12)", "offsetX": "0", "offsetY": "2px", "blur": "4px", "spread": "-1px" }
      ],
      "$type": "shadow",
      "$description": "Primary CTA — hover state."
    },
    "brandLg": {
      "$value": [
        { "color": "rgba(116, 72, 208, 0.3)",  "offsetX": "0", "offsetY": "8px", "blur": "20px", "spread": "-4px" },
        { "color": "rgba(116, 72, 208, 0.15)", "offsetX": "0", "offsetY": "4px", "blur": "8px",  "spread": "-2px" }
      ],
      "$type": "shadow",
      "$description": "Hero CTA, prominent buttons."
    },
    "focusBrand": {
      "$value": [{ "color": "rgba(116, 72, 208, 0.2)", "offsetX": "0", "offsetY": "0", "blur": "0", "spread": "3px" }],
      "$type": "shadow",
      "$description": "Focus ring brand (input focus)."
    },
    "focusError": {
      "$value": [{ "color": "rgba(212, 68, 80, 0.2)", "offsetX": "0", "offsetY": "0", "blur": "0", "spread": "3px" }],
      "$type": "shadow",
      "$description": "Focus ring error (invalid input)."
    }
  },

  "animation": {
    "$description": "Animacje używane w prototypie. Zachowaj timing — to są fizycznie sprawdzone wartości.",
    "duration": {
      "instant":      { "$value": "100ms", "$type": "duration", "$description": "Btn-press translateY(1px)." },
      "fast":         { "$value": "150ms", "$type": "duration", "$description": "Chip-press, hover transitions." },
      "default":      { "$value": "200ms", "$type": "duration", "$description": "Scale-in, backdrop-in." },
      "moderate":     { "$value": "250ms", "$type": "duration", "$description": "Fade-in (modal open)." },
      "slow":         { "$value": "300ms", "$type": "duration", "$description": "Slide-up, slide-in-r (sidepanel)." },
      "spark":        { "$value": "450ms", "$type": "duration", "$description": "DaySpark — kropki schematu." },
      "loadingPhase": { "$value": "700ms", "$type": "duration", "$description": "Faza loading state (4 fazy łącznie ~2.4s)." }
    },
    "easing": {
      "default":   { "$value": "cubic-bezier(0.16, 1, 0.3, 1)",   "$type": "cubicBezier", "$description": "Ease-out-expo. Domyślny easing UI." },
      "spring":    { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)", "$type": "cubicBezier", "$description": "Spring/bounce — daySpark, niewielki overshoot." },
      "easeOut":   { "$value": "ease-out", "$type": "cubicBezier", "$description": "Backdrop fade." },
      "linear":    { "$value": "linear", "$type": "cubicBezier", "$description": "Spinner rotate." }
    },
    "preset": {
      "fadeIn":    { "$value": { "duration": "{animation.duration.moderate}", "easing": "{animation.easing.default}" }, "$type": "transition", "$description": "Modal open, sekcje rozwijane." },
      "slideUp":   { "$value": { "duration": "{animation.duration.slow}", "easing": "{animation.easing.default}" }, "$type": "transition", "$description": "Toast, snackbar." },
      "slideInR":  { "$value": { "duration": "{animation.duration.slow}", "easing": "{animation.easing.default}" }, "$type": "transition", "$description": "Sidepanel z prawej." },
      "scaleIn":   { "$value": { "duration": "{animation.duration.default}", "easing": "{animation.easing.default}" }, "$type": "transition", "$description": "Tooltip, popover." },
      "btnPress":  { "$value": { "duration": "{animation.duration.fast}", "easing": "{animation.easing.default}" }, "$type": "transition", "$description": "Press feedback — translateY(1px)." },
      "chipPress": { "$value": { "duration": "{animation.duration.fast}", "easing": "{animation.easing.default}" }, "$type": "transition", "$description": "Chip toggle — scale(0.97)." },
      "daySpark":  { "$value": { "duration": "{animation.duration.spark}", "easing": "{animation.easing.spring}" }, "$type": "transition", "$description": "Kropki schematu z opóźnieniem 60ms/dot." }
    }
  },

  "z": {
    "$description": "Z-index scale.",
    "base":     { "$value": "0",  "$type": "number" },
    "raised":   { "$value": "10", "$type": "number", "$description": "Sticky elements." },
    "dropdown": { "$value": "20", "$type": "number", "$description": "Dropdowns, popovers." },
    "sticky":   { "$value": "30", "$type": "number", "$description": "Sticky nav, header." },
    "modal":    { "$value": "50", "$type": "number", "$description": "Modal, sidepanel, backdrop." },
    "toast":    { "$value": "60", "$type": "number", "$description": "Toast/notifications nad wszystkim." }
  }
}
